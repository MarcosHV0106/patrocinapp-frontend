# =========================================================
# Patrocinapp Angular - .gitignore
# =========================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Angular build output
dist/
.angular/
.cache/

# Coverage
coverage/
.nyc_output/

# Environment files
.env
.env.*
!.env.example

# Local IDE/editor files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
logs/
*.log

# Temporary files
tmp/
temp/

# TypeScript incremental build info
*.tsbuildinfo

# Angular local configuration
.angular/cache/

# Package manager caches
.pnpm-store/
.yarn/
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# Optional: lock files from other package managers
# Keep package-lock.json if you use npm.
# Uncomment only if you are NOT using these managers.
# yarn.lock
# pnpm-lock.yaml

# Optional: generated files
*.tgz

# Optional: local test artifacts
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# Local Firebase / deployment configs, if used later
.firebase/
firebase-debug.log
